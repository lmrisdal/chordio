{
  "scan_interval_sec": 2,
  "devices": ["/dev/input/by-id/usb-Microsoft_X-Box_Controller-event-joystick"],
  "device_ids": [],
  "chords": [
    {
      "name": "volume-up",
      "chord": ["BTN_THUMBL", "BTN_TR", "BTN_WEST"],
      "cooldown_ms": 1000,
      "action": {
        "type": "exec",
        "command": ["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", "5%+"]
      }
    }
  ]
}
